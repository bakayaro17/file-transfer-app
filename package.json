{
  "name": "file-transfer-app",
  "version": "1.0.8",
  "description": "Cross-platform peer-to-peer file transfer built with Electron and PeerJS",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/bakayaro17/file-transfer-app.git"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "release": "electron-builder --win --publish always",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "peerjs": "^1.5.5"
  },
  "build": {
    "appId": "com.elvis.filetransferapp",
    "productName": "File Transfer App",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "icon.png"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "bakayaro17",
      "repo": "file-transfer-app",
      "releaseType": "draft"
    },
    "protocols": [
      {
        "name": "File Transfer",
        "schemes": [
          "filetransfer"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icon.png",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    }
  }
}
